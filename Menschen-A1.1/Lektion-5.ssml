  <voice name="de-DE-Chirp3-HD-Charon">Der Tisch ist eckig.</voice> <break time="4s"/>

  <voice name="de-DE-Chirp3-HD-Charon"><prosody rate="0.85">sportlich</prosody></voice> <break time="2.5s"/> <voice name="de-DE-Chirp3-HD-Charon"><prosody rate="0.85">sportlich</prosody></voice> <break time="2.5s"/> <voice name="de-DE-Chirp3-HD-Charon"><prosody rate="0.85">sportlich.</prosody></voice> <break time="2.5s"/>
