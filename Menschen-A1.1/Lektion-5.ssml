<speak>
  <voice name="de-DE-Chirp3-HD-Charon">Menschen A1.1. Lektion 5. Was ist das? Das ist ein F.</voice> <break time="4s"/>

  <voice name="de-DE-Chirp3-HD-Charon"><prosody rate="0.85">neu</prosody></voice> <break time="2.5s"/> <voice name="de-DE-Chirp3-HD-Charon"><prosody rate="0.85">neu</prosody></voice> <break time="2.5s"/> <voice name="de-DE-Chirp3-HD-Charon"><prosody rate="0.85">neu.</prosody></voice> <break time="2.5s"/>
  <voice name="de-DE-Chirp3-HD-Charon">Das Buch ist neu.</voice> <break time="4s"/>

  <voice name="de-DE-Chirp3-HD-Charon"><prosody rate="0.85">elegant</prosody></voice> <break time="2.5s"/> <voice name="de-DE-Chirp3-HD-Charon"><prosody rate="0.85">elegant</prosody></voice> <break time="2.5s"/> <voice name="de-DE-Chirp3-HD-Charon"><prosody rate="0.85">elegant.</prosody></voice> <break time="2.5s"/>
  <voice name="de-DE-Chirp3-HD-Charon">Die Brille ist elegant.</voice> <break time="4s"/>

