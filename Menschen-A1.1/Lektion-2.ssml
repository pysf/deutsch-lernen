  <voice name="de-DE-Chirp3-HD-Puck"><prosody rate="0.85">der Schauspieler</prosody></voice> <break time="2.5s"/> <voice name="de-DE-Chirp3-HD-Puck"><prosody rate="0.85">der Schauspieler</prosody></voice> <break time="2.5s"/> <voice name="de-DE-Chirp3-HD-Puck"><prosody rate="0.85">der Schauspieler.</prosody></voice> <break time="2.5s"/>
